{
    "name": "@isdmx/markmap-server",
    "description": "Web server for converting Markdown to interactive mind maps with export support (PNG/JPG/SVG)",
    "version": "0.1.0",
    "author": "isdmx",
    "main": "./build/index.js",
    "keywords": [
        "markmap",
        "mindmap",
        "mindnode",
        "xmind",
        "markdown",
        "html"
    ],
    "scripts": {
        "test": "vitest run | pino-pretty",
        "test:watch": "vitest watch",
        "build": "tsc && chmod u+x build/index.js",
        "start": "node build/index.js",
        "dev": "tsc-watch --onSuccess \"node build/index.js\" | pino-pretty",
        "format": "prettier --write . --ignore-path .gitignore",
        "prepare": "husky"
    },
    "bin": {
        "markmap-server": "build/index.js"
    },
    "type": "module",
    "files": [
        "build"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/isdmx/markmap-server.git"
    },
    "lint-staged": {
        "*.{js,ts,jsx,tsx}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{md,json,yml,yaml,html,css}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^5.2.1",
        "markmap-cli": "^0.18.12",
        "minimist": "^1.2.8",
        "open": "^11.0.0",
        "pino": "^10.1.0",
        "prom-client": "^15.1.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/minimist": "^1.2.5",
        "@types/node": "^24.10.1",
        "esbuild": "^0.27.0",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "globals": "^16.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.7.4",
        "prettier-plugin-organize-imports": "^4.3.0",
        "tsc-watch": "7.2.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.48.1",
        "vite": "^7.2.6",
        "vitest": "^4.0.15"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.53.3"
    }
}
